{
  "name": "comix-management-tool",
  "version": "1.9.5",
  "description": "Comic archive conversion and management tool",
  "main": "main.js",
  "scripts": {
    "start":          "electron .",
    "prepare-vendor": "node scripts/prepare-vendor.js",
    "build":          "electron-builder --win --publish always",
    "release":        "node scripts/release.mjs",
    "postbuild":      "node scripts/cleanup-releases.js",
    "pack":           "electron-builder --win --publish never",
    "dist":           "electron-builder --win --publish never && node scripts/stamp-icon.js"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron":         "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId":       "com.antigravity.comixmanagementtool",
    "productName": "ComixManagementTool",
    "copyright":   "Antigravity Projects",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "src/**",
      "node_modules/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**"
    ],
    "extraResources": [
      {
        "from": "vendor/7zip",
        "to":   "7zip",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "publish": {
      "provider": "github",
      "owner": "Gemanoneko",
      "repo": "ComixManagementTool",
      "releaseType": "release"
    }
  }
}
